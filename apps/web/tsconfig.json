{
  "extends": "@ecommerce/typescript-config/nextjs.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ]
    },
    "noEmit": true,
    "isolatedModules": true
  },
  "include": [
    "../../packages/typescript-config/src",
    "../../packages/typescript-config/next.config.ts",
    "../../packages/typescript-config/next-env.d.ts",
    "../../packages/typescript-config/.next/types/**/*.ts",
    ".next/types/**/*.ts"
  ]
}
